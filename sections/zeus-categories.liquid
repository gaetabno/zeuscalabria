{{ 'zeus-categories.css' | asset_url | stylesheet_tag }}

<!-- Splide CSS & JS (CDN) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">
<div class="zeus-categories page-width" style="--columns-desktop: {{ section.settings.columns_desktop }};">
  {% if section.settings.title != blank %}
    <h2 class="zeus-categories__title h2">{{ section.settings.title | escape }}</h2>
  {% endif %}

  <div class="splide zeus-categories-splide" id="splide-{{ section.id }}">
    <div class="splide__track">
      <ul
        class="splide__list zeus-categories__list"
        role="list"
      >
        {%- for block in section.blocks -%}
          <li class="splide__slide zeus-categories__item" {{ block.shopify_attributes }}>
            <a
              href="{{ block.settings.collection.url | default: block.settings.link | default: '#' }}"
              class="zeus-categories__card"
              style="--card-bg: {{ block.settings.bg_color | default: '#0a1c3e' }};"
            >
              <div class="zeus-categories__image-wrapper">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag: loading: 'lazy', class: 'zeus-categories__image'
                  }}
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg zeus-categories__image' }}
                {%- endif -%}
              </div>
              <div class="zeus-categories__content">
                <h3 class="zeus-categories__heading">{{ block.settings.title | escape }}</h3>
              </div>
            </a>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>

<script>
  function initZeusSplide() {
    var el = document.querySelector('#splide-{{ section.id }}');
    var isSwipeEnabled = {{ section.settings.swipe_on_mobile | json }};

    if (isSwipeEnabled && el && !el.classList.contains('is-initialized')) {
      new Splide(el, {
        speed: 800,
        perPage: 1,
        gap: '0.5rem',
        padding: { right: '25%' }, /* Show 1 slide and 1/4 of the next */
        pagination: true,
        arrows: false,
        mediaQuery: 'min',
        breakpoints: {
          768: {
            destroy: true // Destroys Splide on tablet/desktop to return to native CSS Grid
          }
        }
      }).mount();
    }
  }

  document.addEventListener('DOMContentLoaded', initZeusSplide);
  document.addEventListener('shopify:section:load', function(e) {
    if (e.detail.sectionId === '{{ section.id }}') initZeusSplide();
  });
</script>

{% schema %}
{
  "name": "Zeus Categories",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Categorie",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "label": "Number of columns on desktop"
    },
    {
      "type": "checkbox",
      "id": "swipe_on_mobile",
      "default": true,
      "label": "Enable swipe on mobile"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#1a3b65"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Category",
          "label": "Title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Fallback Link (if no collection)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zeus Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Uomo",
            "bg_color": "#1a3b65"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Donna",
            "bg_color": "#8c1f28"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Bambino",
            "bg_color": "#0d1b2a"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "FC Crotone",
            "bg_color": "#1a2444"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Accessori",
            "bg_color": "#234125"
          }
        }
      ]
    }
  ]
}
{% endschema %}
