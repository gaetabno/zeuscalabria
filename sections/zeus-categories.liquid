{{ 'zeus-categories.css' | asset_url | stylesheet_tag }}

<div class="zeus-categories page-width">
  {% if section.settings.title != blank %}
    <h2 class="zeus-categories__title h2">{{ section.settings.title | escape }}</h2>
  {% endif %}

  <ul class="zeus-categories__list" role="list">
    {%- for block in section.blocks -%}
      <li class="zeus-categories__item" {{ block.shopify_attributes }}>
        <a href="{{ block.settings.link | default: '#' }}" class="zeus-categories__card zeus-categories__card--gradient-{{ block.settings.gradient_theme }}">
          <div class="zeus-categories__image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'zeus-categories__image' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg zeus-categories__image' }}
            {%- endif -%}
          </div>
          <div class="zeus-categories__content">
            <h3 class="zeus-categories__heading">{{ block.settings.title | escape }}</h3>
          </div>
        </a>
      </li>
    {%- endfor -%}
  </ul>
</div>

{% schema %}
{
  "name": "Zeus Categories",
  "tag": "section",
  "class": "section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "CATEGORIE",
      "label": "Heading"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Category",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "gradient_theme",
          "options": [
            {
              "value": "blue",
              "label": "Blue (Uomo)"
            },
            {
              "value": "red",
              "label": "Red (Donna)"
            },
            {
              "value": "navy",
              "label": "Dark Navy (Bambino / Crotone)"
            },
            {
              "value": "green",
              "label": "Green (Accessori)"
            }
          ],
          "default": "blue",
          "label": "Gradient Theme"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zeus Categories",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Uomo",
            "gradient_theme": "blue"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Donna",
            "gradient_theme": "red"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Bambino",
            "gradient_theme": "navy"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "FC Crotone",
            "gradient_theme": "navy"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Accessori",
            "gradient_theme": "green"
          }
        }
      ]
    }
  ]
}
{% endschema %}
